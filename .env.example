HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
HEADLESS=true
PRETTY_LOGS=true
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080
CAPTURE_TIMEOUT_MS=120000
MAX_CONCURRENT_CAPTURES=1
USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 14_0) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36
CHROME_USER_DATA_DIR=.auth/chrome-user-data
GOOGLE_STORAGE_STATE_PATH=.auth/google-storage-state.json
GOOGLE_EMAIL=
GOOGLE_PASSWORD=
GOOGLE_AUTH_HEADLESS=false
GOOGLE_AUTH_BROWSER_CHANNEL=chrome
GOOGLE_AUTH_TIMEOUT_MS=180000
